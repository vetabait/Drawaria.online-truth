Player sniper: This is a nice tool which can find the your wanted player without switching rooms, because bot will do it insted of you
Use script carefully, not recommended to use when mods are mostly active

!! IMPORTANT !!
Always turn on Deep search in settings, so script will switch rooms until he will found a wanted target

Script shouldnt be published, but since i found another methods, let this script to see the internet



// ==UserScript==
// @name Player sniper
// @namespace http://tampermonkey.net/
// @version 2.11
// @description Sniping players using username or UID
// @author August10Loop 
// @match https://drawaria.online/*
// @icon https://www.google.com/s2/favicons?sz=64&domain=drawaria.online
// @grant none
// @run-at document-start
// ==/UserScript==
(function() {
    'use strict';
    let menuVisible = false;
    let sniperBot = null;
    let isSniping = false;
    let startingRoom = null;
    let currentRoomIndex = 0;
    let targetNickname = '';
    let targetUID = '';
    const maxRooms = 10;
    let snipeLogs = []; // Array to store snipe logs if you will reload if you will lose info)
    let globalLogs = []; // Array to store global logs (if you will reload if you will lose info)
    let deepSearch = false;
    console.log('Sniper Script started at', new Date().toLocaleString());
    function delay(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }
    async function switchToNextRoom() {
        if (!sniperBot || !sniperBot.conn.socket || sniperBot.conn.socket.readyState !== WebSocket.OPEN) {
            console.log('Sniper: Bot not active or WebSocket closed, stopping room switch at', new Date().toLocaleString());
            return;
        }
        console.log('Sniper: Initiating room switch via bot WebSocket at', new Date().toLocaleString());
        sniperBot.room.next();
    }
    const Player = function (name) {
        this.name = name;
        this.sid1 = null;
        this.uid = '';
        this.wt = '';
        this.conn = new Connection(this);
        this.room = new Room(this.conn);
    };
    const Connection = function (player) {
        this.player = player;
        this.socket = null;
    };
    Connection.prototype.onopen = function () {
        console.log('Sniper: WebSocket opened for', this.player.name, 'at', new Date().toLocaleString());
        this.Heartbeat(25000);
    };
    Connection.prototype.onclose = function () {
        console.log('Sniper: WebSocket closed for', this.player.name, 'at', new Date().toLocaleString());
        sniperBot = null;
    };
    Connection.prototype.onerror = function (event) {
        console.error('Sniper: WebSocket error for', this.player.name, ':', event, 'at', new Date().toLocaleString());
        updateSnipeResult('Connection error', '', 'Failed to connect to server.');
        endSnipe(false);
    };
    Connection.prototype.onmessage = function (event) {
        const message = String(event.data);
        if (message.startsWith('42')) {
            this.onbroadcast(message.slice(2));
        } else if (message.startsWith('40')) {
            this.onrequest();
        } else if (message.startsWith('41')) {
            console.log('Sniper: WebSocket 41 detected, stopping bot at', new Date().toLocaleString());
            this.close();
        } else if (message.startsWith('430')) {
            const configs = JSON.parse(message.slice(3))[0];
            this.player.room.players = configs.players;
            this.player.room.id = configs.roomid;
            console.log('Sniper: Bot joined room', this.player.room.id, 'Players:', this.player.room.players, 'at', new Date().toLocaleString());
            checkPlayersInRoom();
        }
    };
    Connection.prototype.onbroadcast = function (payload) {
        const data = JSON.parse(payload);
        if (data[0] === 'bc_uc_freedrawsession_changedroom') {
            this.player.room.players = data[3];
            this.player.room.id = data[4];
            console.log('Sniper: Bot switched to new room', this.player.room.id, 'Players:', this.player.room.players, 'at', new Date().toLocaleString());
            checkPlayersInRoom();
        } else if (data[0] === 'mc_roomplayerschange') {
            this.player.room.players = data[3];
            console.log('Sniper: Players updated:', this.player.room.players);
            checkPlayersInRoom();
        }
    };
    Connection.prototype.onrequest = function () {};
    Connection.prototype.open = function (url) {
        this.socket = new WebSocket(url);
        window.sockets.push(this.socket);
        this.socket.onopen = this.onopen.bind(this);
        this.socket.onclose = this.onclose.bind(this);
        this.socket.onerror = this.onerror.bind(this);
        this.socket.onmessage = this.onmessage.bind(this);
    };
    Connection.prototype.close = function () {
        if (this.socket && this.socket.readyState !== WebSocket.CLOSED) {
            this.socket.send('41');
            this.socket.send('40');
            this.socket.close();
        }
        sniperBot = null;
    };
    Connection.prototype.Heartbeat = function (interval) {
        setTimeout(() => {
            if (this.socket && this.socket.readyState === WebSocket.OPEN) {
                this.socket.send('2');
                console.log('Sniper: Heartbeat sent for', this.player.name, 'at', new Date().toLocaleString());
                this.Heartbeat(interval);
            }
        }, interval);
    };
    Connection.prototype.serverconnect = function (server, room) {
        if (!this.socket || this.socket.readyState !== WebSocket.OPEN) {
            this.open(server);
        } else {
            this.socket.send('41');
            this.socket.send('40');
        }
        this.onrequest = () => {
            this.socket.send(room);
        };
    };
    const Room = function (conn) {
        this.conn = conn;
        this.id = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx';
        this.players = [];
    };
    Room.prototype.join = function (invitelink) {
        let gamemode = 2;
        let server = '';
        if (invitelink == null) {
            this.id = null;
            server = 'sv3.';
        } else {
            this.id = invitelink.startsWith('http') ? invitelink.split('/').pop() : invitelink;
            if (invitelink.endsWith('.3')) {
                server = 'sv3.';
                gamemode = 2;
            } else if (invitelink.endsWith('.2')) {
                server = 'sv2.';
                gamemode = 2;
            } else {
                server = '';
                gamemode = 1;
            }
        }
        const serverurl = `wss://${server}drawaria.online/socket.io/?sid1=undefined&hostname=drawaria.online&EIO=3&transport=websocket`;
        const connectstring = `420["startplay","${this.conn.player.name}",${gamemode},"en",${nullify(this.id)},null,[null,"https://drawaria.online/",1000,1000,[${nullify(this.conn.player.sid1)},${nullify(this.conn.player.uid)},${nullify(this.conn.player.wt)}],null]]`;
        this.conn.serverconnect(serverurl, connectstring);
    };
    Room.prototype.next = function () {
        if (this.conn.socket.readyState !== WebSocket.OPEN) {
            console.log('Sniper: WebSocket not open, cannot switch room at', new Date().toLocaleString());
            return;
        }
        this.conn.socket.send('42["pgswtichroom"]');
    };
    const nullify = (value = null) => {
        return value == null ? null : `"${value}"`;
    };
    // Override window.alert to handle disconnects
    const originalAlert = window.alert;
    window.alert = function(message) {
        if (message && (message.includes("Vote kicked") || message.includes("Disconnected from server") || message.includes("Moderator: Reset avatar image") || message.includes("Room is full"))) {
            console.log(`Sniper: Alert detected: ${message}, stopping bot at ${new Date().toLocaleString()}`);
            if (sniperBot) {
                sniperBot.conn.close();
                sniperBot = null;
                updateSnipeResult('Bot stopped', '', message);
            }
            return;
        }
        console.log(`Sniper: Non-suppressed alert: ${message} at ${new Date().toLocaleString()}`);
        return originalAlert.apply(this, arguments);
    };
    function toggleSnipe() {
        const snipeButton = document.querySelector('.snipe-button');
        if (isSniping) {
            console.log('Sniper: Stopping bot at', new Date().toLocaleString());
            if (sniperBot) {
                sniperBot.conn.close();
            }
            sniperBot = null;
            isSniping = false;
            snipeButton.textContent = 'Snipe!';
            snipeButton.title = 'Start snipe';
            return;
        }
        targetNickname = document.querySelector('#sniper-menu input[placeholder="Enter player name"]').value.trim();
        targetUID = document.querySelector('#sniper-menu input[placeholder="Enter player UID (optional)"]').value.trim();
        if (!targetNickname && !targetUID) {
            originalAlert('Please enter a player name or UID.');
            return;
        }
        isSniping = true;
        currentRoomIndex = 0;
        console.log('Sniper: Starting snipe for', targetNickname || '(no name)', 'UID:', targetUID || '(no UID)', 'at', new Date().toLocaleString());
        const invurlInput = document.getElementById('invurl');
        startingRoom = invurlInput ? invurlInput.value : null;
        sniperBot = new Player('BigJim');
        sniperBot.room.join(startingRoom);
        snipeButton.textContent = 'Stop';
        snipeButton.title = 'Stop snipe';
    }
    async function checkPlayersInRoom() {
        if (!isSniping) return;
        let players = sniperBot.room.players || [];
        console.log('Sniper: Checking players in room', sniperBot.room.id, players);
        const roomUrl = `https://drawaria.online/room/${sniperBot.room.id}`;
        globalLogs.push({
            roomUrl: roomUrl,
            players: players.map(p => ({
                name: p.name,
                uid: p.avatarid ? p.avatarid.split('.')[0] : 'default'
            })),
            timestamp: new Date()
        });
        let targetPlayer = players.find(player =>
            (targetNickname && player.name === targetNickname) ||
            (targetUID && player.avatarid && player.avatarid.split('.')[0] === targetUID)
        );
        if (targetPlayer) {
            snipeLogs.push({ nickname: targetPlayer.name, roomUrl: roomUrl, timestamp: new Date() });
            updateSnipeResult('Player sniped!', roomUrl);
            sniperBot.conn.close(); // Disconnect bot when player is found
            endSnipe(true);
        } else {
            currentRoomIndex++;
            if (deepSearch || currentRoomIndex < maxRooms) {
                console.log('Sniper: Player not found, waiting 1 second before switching to next room at', new Date().toLocaleString());
                await delay(1000);
                switchToNextRoom();
            } else {
                updateSnipeResult('Player not sniped (Try search deep)', '', 'Player not in the game or room is full.');
                sniperBot.conn.close(); // bot will be disconnected if player wont found
                endSnipe(false);
            }
        }
    }
    function endSnipe(found) {
        if (!isSniping) return;
        isSniping = false;
        const snipeButton = document.querySelector('.snipe-button');
        snipeButton.textContent = 'Snipe!';
        snipeButton.title = 'Start snipe';
        sniperBot = null;
    }
