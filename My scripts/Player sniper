    function updateSnipeResult(text, link = '', subtext = '') {
        let content = document.querySelector('.sniper-menu-content');
        let result = content.querySelector('.snipe-result');
        if (!result) {
            result = document.createElement('div');
            result.className = 'snipe-result';
            content.insertBefore(result, content.querySelector('.snipe-button'));
        }
        if (link) {
            result.innerHTML = `${text} <a href="${link}" target="_blank">Link</a>`;
        } else {
            result.innerHTML = text;
        }
        let subtextEl = content.querySelector('.snipe-subtext');
        if (subtext) {
            if (!subtextEl) {
                subtextEl = document.createElement('div');
                subtextEl.className = 'snipe-subtext';
                content.appendChild(subtextEl);
            }
            subtextEl.textContent = subtext;
        } else if (subtextEl) {
            subtextEl.remove();
        }
        setTimeout(() => {
            result.innerHTML = '';
            if (subtextEl) subtextEl.textContent = '';
            const snipeButton = document.querySelector('.snipe-button');
            snipeButton.textContent = 'Snipe!';
            snipeButton.title = 'Start snipe';
        }, 5000);
    }
    let logsVisible = false;
    function toggleLogs() {
        const logs = document.getElementById('sniper-logs');
        logsVisible = !logsVisible;
        logs.style.display = logsVisible ? 'block' : 'none';
        if (logsVisible) {
            renderLogs();
        }
    }
    // Function to render snipe logs
    function renderLogs(searchQuery = '') {
        const logsContent = document.querySelector('.sniper-logs-content');
        logsContent.innerHTML = '';
        const filteredLogs = searchQuery
            ? snipeLogs.filter(log => log.nickname.toLowerCase().includes(searchQuery.toLowerCase()))
            : snipeLogs;
        filteredLogs.forEach(log => {
            const logEntry = document.createElement('div');
            logEntry.innerHTML = `${log.nickname} - <a href="${log.roomUrl}" target="_blank">${log.roomUrl}</a> (${log.timestamp.toLocaleString()})`;
            logsContent.appendChild(logEntry);
        });
    }
    let globalLogsVisible = false;
    function toggleGlobalLogs() {
        const globalLogsDiv = document.getElementById('global-logs');
        globalLogsVisible = !globalLogsVisible;
        globalLogsDiv.style.display = globalLogsVisible ? 'block' : 'none';
        if (globalLogsVisible) {
            renderGlobalLogs();
        }
    }
    function renderGlobalLogs(searchQuery = '') {
        const logsContent = document.querySelector('.global-logs-content');
        logsContent.innerHTML = '';
        const filteredLogs = searchQuery
            ? globalLogs.filter(log => log.players.some(player =>
                player.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
                player.uid.toLowerCase().includes(searchQuery.toLowerCase())
              ))
            : globalLogs;
        filteredLogs.forEach(log => {
            const logEntry = document.createElement('div');
            logEntry.innerHTML = `Room: <a href="${log.roomUrl}" target="_blank">${log.roomUrl}</a> (${log.timestamp.toLocaleString()})`;
            const playerList = document.createElement('ul');
            log.players.forEach(player => {
                const playerItem = document.createElement('li');
                playerItem.textContent = `${player.name} (UID: ${player.uid})`;
                playerList.appendChild(playerItem);
            });
            logEntry.appendChild(playerList);
            logsContent.appendChild(logEntry);
        });
    }
