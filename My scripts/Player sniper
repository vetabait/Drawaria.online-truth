    function startPlayerObserver() {
        console.log('Starting MutationObserver for player nicknames filtering at', new Date().toLocaleString());
        const observer = new MutationObserver((mutationsList) => {
            for (const mutation of mutationsList) {
                if (mutation.type === 'childList' && mutation.addedNodes.length > 0) {
                    mutation.addedNodes.forEach((node) => {
                        if (node.nodeType === 1 && node.classList?.contains('player')) {
                            const nameContent = node.textContent.trim().toLowerCase();
                            console.log('Detected player:', node.textContent);
                            if (BLACKLIST.symbols.some(symbol => nameContent.includes(symbol)) ||
                                BLACKLIST.texts.some(text => nameContent.includes(text.trim().toLowerCase()))) {
                                console.log('Removed player:', node.textContent);
                                node.remove();
                            }
                        }
                    });
                }
            }
        });
        observer.observe(document.body, { childList: true, subtree: true });
    }
    window.addEventListener('load', function() {
        console.log('0', new Date().toLocaleString());
        startPlayerObserver();
    });
