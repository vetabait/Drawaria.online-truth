                deepSearch = deepSearchCheckbox.checked;
            });
            const globalSearchInput = document.querySelector('.global-logs-controls input');
            const globalReloadButton = document.querySelector('.global-logs-controls .reload-button');
            globalReloadButton.addEventListener('click', () => renderGlobalLogs(globalSearchInput.value));
            globalSearchInput.addEventListener('input', () => renderGlobalLogs(globalSearchInput.value));
        }
    }
    function toggleSniperMenu() {
        const menu = document.getElementById('sniper-menu');
        if (menu) {
            menuVisible = !menuVisible;
            menu.style.display = menuVisible ? 'block' : 'none';
        }
